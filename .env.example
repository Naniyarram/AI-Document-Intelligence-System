# ─────────────────────────────────────────────────────────
# .env — AI Document Intelligence System Configuration
#
# Copy this file: copy .env.example .env  (Windows)
#                 cp .env.example .env    (Mac/Linux)
# Then fill in YOUR API key below.
# ─────────────────────────────────────────────────────────

# ── API Key ───────────────────────────────────────────────
# IMPORTANT: Do NOT put quotes around the key value.
#
# Option A: HuggingFace (key starts with hf_)
#   Get free at: https://huggingface.co/settings/tokens
#
# Option B: OpenRouter (key starts with sk-or-)
#   Get free at: https://openrouter.ai
#
# The code auto-detects which provider you are using.
# Just paste your key — nothing else needs to change.

HF_API_KEY=hf_your_token_here
# OPENROUTER_API_KEY=sk-or-your-key-here

# ── Model Names (optional overrides) ─────────────────────
# Leave blank to use smart defaults for your provider.
# HuggingFace defaults: meta-llama/Llama-3.1-8B-Instruct / Qwen2.5-VL-7B-Instruct
# OpenRouter defaults : mistral-7b-instruct:free / qwen-2.5-vl-7b-instruct:free
# LLM_MODEL=
# VLM_MODEL=

# ── Chunking ──────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=60

# ── Retrieval ─────────────────────────────────────────────
BM25_TOP_K=15
DENSE_TOP_K=15
RERANKER_TOP_K=5
